{
  "author": "Divyanshu Soni <hello@divyanshusoni.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcs-soni/promptenhance"
  },
  "homepage": "https://github.com/dcs-soni/promptenhance#readme",
  "name": "@promptenhance/core",
  "version": "0.1.2",
  "description": "Core engine for PromptEnhance - codebase indexing, context retrieval, and prompt enhancement",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build && npm run copy:wasm",
    "copy:wasm": "node -e \"const fs = require('fs'); fs.mkdirSync('dist/wasm', {recursive: true}); fs.readdirSync('wasm').forEach(f => fs.copyFileSync('wasm/' + f, 'dist/wasm/' + f));\"",
    "dev": "tsc --watch",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "prompt",
    "context",
    "indexer"
  ],
  "license": "MIT",
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.8",
    "chokidar": "^3.5.3",
    "chromadb": "^3.0.17",
    "glob": "^11.0.0",
    "ignore": "^5.3.0",
    "openai": "^6.9.1",
    "web-tree-sitter": "^0.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
